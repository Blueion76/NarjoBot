# ── Required ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-bot-token-here
MOD_ROLE_ID=000000000000000000        # Role allowed to mark Fixed / Needs Info / Won't Fix

# ── Optional ───────────────────────────────────────────────────────────────────
PLATFORM_HINT="Narjo 1.3(70) - iOS 26.4"   # Shown in the bug report modal placeholder

# ── Forum channel IDs ─────────────────────────────────────────────────────────
FORUM_NAVIDROME_ID=000000000000000000
FORUM_PLEX_ID=000000000000000000
FORUM_JELLYFIN_ID=000000000000000000
FORUM_EMBY_ID=000000000000000000

# ── Tag names (shared across forums) ─────────────────────────────────────────
# The bot now finds tags by NAME in each forum, so you do NOT need tag IDs.
# Make sure each forum has tags with these exact names.
TAG_NAME_UNRESOLVED=Unresolved
TAG_NAME_NEEDS_INFO=Needs Info
TAG_NAME_FIXED=Fixed
TAG_NAME_WONT_FIX=Won't Fix

TAG_NAME_OTHER=Other
TAG_NAME_UI=UI
TAG_NAME_SYNC=Sync / Library
TAG_NAME_PERFORMANCE=Performance
TAG_NAME_AUTH=Auth
