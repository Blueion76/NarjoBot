# ── Required ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-bot-token-here
MOD_ROLE_ID=000000000000000000        # Role allowed to mark Fixed / Needs Info / Won't Fix

# ── Forum channel IDs ─────────────────────────────────────────────────────────
FORUM_NAVIDROME_ID=000000000000000000
FORUM_PLEX_ID=000000000000000000
FORUM_JELLYFIN_ID=000000000000000000
FORUM_EMBY_ID=000000000000000000

# ── Status tag IDs ─────────────────────────────────────────────────────────────
# Create these four tags in EACH forum channel, then run !listtags to get IDs.
# Tag IDs are per-channel — if your four forums have different IDs for the same
# tag name, see the README for how to handle that.
TAG_UNRESOLVED=000000000000000000
TAG_NEEDS_INFO=000000000000000000
TAG_FIXED=000000000000000000
TAG_WONT_FIX=000000000000000000
