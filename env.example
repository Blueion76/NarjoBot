# ── Required ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-bot-token-here
MOD_ROLE_ID=000000000000000000        # Role allowed to mark Fixed / Needs Info / Won't Fix

# ── Optional ───────────────────────────────────────────────────────────────────
PLATFORM_HINT="Narjo 1.3(70) - iOS 26.4"   # Shown in the bug report modal placeholder

# ── Forum channel IDs ─────────────────────────────────────────────────────────
FORUM_NAVIDROME_ID=000000000000000000
FORUM_PLEX_ID=000000000000000000
FORUM_JELLYFIN_ID=000000000000000000
FORUM_EMBY_ID=000000000000000000

# ── Status tag IDs (per forum) ────────────────────────────────────────────────
# Create the four status tags in EACH forum channel, then run !listtags to get IDs.
# Tags are per-channel, so each forum needs its own set.

# Navidrome
NAVIDROME_TAG_UNRESOLVED=000000000000000000
NAVIDROME_TAG_NEEDS_INFO=000000000000000000
NAVIDROME_TAG_FIXED=000000000000000000
NAVIDROME_TAG_WONT_FIX=000000000000000000

# Plex
PLEX_TAG_UNRESOLVED=000000000000000000
PLEX_TAG_NEEDS_INFO=000000000000000000
PLEX_TAG_FIXED=000000000000000000
PLEX_TAG_WONT_FIX=000000000000000000

# Jellyfin
JELLYFIN_TAG_UNRESOLVED=000000000000000000
JELLYFIN_TAG_NEEDS_INFO=000000000000000000
JELLYFIN_TAG_FIXED=000000000000000000
JELLYFIN_TAG_WONT_FIX=000000000000000000

# Emby
EMBY_TAG_UNRESOLVED=000000000000000000
EMBY_TAG_NEEDS_INFO=000000000000000000
EMBY_TAG_FIXED=000000000000000000
EMBY_TAG_WONT_FIX=000000000000000000
